APP_ENV=production
APP_DEBUG=false
APP_URL=https://builder.custode.digital
APP_TIMEZONE=Europe/Zurich

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=custode_builder
DB_USER=
DB_PASS=

# claude | kimi
GENERATION_PROVIDER=claude

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

KIMI_API_KEY=
KIMI_MODEL=kimi-k2.5
# Optional — set both to enable cost tracking (CNY/USD per million tokens)
KIMI_PRICE_IN_PER_MTOK=
KIMI_PRICE_OUT_PER_MTOK=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SETUP_AMOUNT_CENTS=14900
STRIPE_CURRENCY=chf
STRIPE_MONTHLY_PRICE_ID=
STRIPE_MONTHLY_LABEL_CENTS=4900

CPANEL_HOST=
CPANEL_USER=
CPANEL_TOKEN=
CPANEL_BASE_DOMAIN=custode.digital
CPANEL_ENABLE_SUBDOMAIN=false

ADMIN_SESSION_NAME=custode_admin
ADMIN_USER=admin
ADMIN_PASSWORD_HASH=

MAIL_DRIVER=log
MAIL_FROM=noreply@custode.digital
MAIL_ADMIN_ALERT=

RATE_LIMIT_BRIEF_PER_HOUR=30
RATE_LIMIT_CHECKOUT_PER_HOUR=40
RATE_LIMIT_ADMIN_API_PER_MINUTE=120
